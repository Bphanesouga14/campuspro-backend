# Base de données Principale: supabase (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:supabase14.Com@db.biftryazdcxzvcwnqfcw.supabase.co:5432/postgres
DB_HOST=db.biftryazdcxzvcwnqfcw.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=supabase14.Com

# Base de données DE SECOURS : PostgreSQL local 
# Format : postgresql+asyncpg://USER:PASSWORD@HOST:PORT/NOM_BASE
# Laisser vide si vous n'avez pas de PostgreSQL local
LOCAL_DATABASE_URL=postgresql+asyncpg://postgres:12345@localhost:5432/lgs_local

# ── Priorité de connexion ────────────────────────────────────
# supabase → Essaie Supabase d'abord, local en secours (défaut)
# local    → Essaie le local d'abord, Supabase en secours
#            (utile pour travailler hors connexion internet)
DATABASE_PRIORITY=supabase



# Application
DEBUG=true
APP_TITLE=LGS — Logiciel de Gestion Scolaire
APP_VERSION=1.0.0
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Email (SMTP) — laisser vide pour simuler en dev
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASSWORD=votre_mot_de_passe

# SMS — laisser vide pour simuler en dev
SMS_API_KEY=
SMS_USERNAME=


# ── Authentification JWT ─────────────────────────────────────
# Génère une clé avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=remplace_moi_par_une_cle_aleatoire_longue_et_secrete
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480
